# ひにち AI News - Environment Variables (Phase 1)
#
# Phase 1 (MVP) does NOT require any API keys. All sources are unauthenticated:
#   - Hacker News Firebase API (https://hacker-news.firebaseio.com/v0/)
#   - HuggingFace Daily Papers (https://huggingface.co/api/daily_papers)
#   - HN RSS (https://hnrss.org/newest)
#
# Future phases may add the following — copy this file to `.env` and fill in
# values when needed:
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=

# Google Analytics 4 Measurement ID (取得後に設定)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
