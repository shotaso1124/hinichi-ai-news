# ひにち AI News - Environment Variables
#
# データソース (Phase 1 / 認証不要):
#   - Hacker News Firebase API (https://hacker-news.firebaseio.com/v0/)
#   - HuggingFace Daily Papers (https://huggingface.co/api/daily_papers)
#   - HN RSS (https://hnrss.org/newest)
#
# 任意 API キー:
#   - ANTHROPIC_API_KEY: 記事タイトルを Claude Haiku で日本語訳するために使用。
#     未設定 / 無効値の場合は原題のまま表示される(フォールバック動作)。
#
# OPENAI_API_KEY=
# GITHUB_TOKEN=

# Anthropic Claude API キー(タイトル翻訳用・任意)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXX

# Google Analytics 4 Measurement ID (取得後に設定)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
