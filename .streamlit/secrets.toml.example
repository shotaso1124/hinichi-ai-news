# Streamlit Cloud の Secrets に登録する値（ローカル開発用テンプレート）
#
# 使い方:
#   1. このファイルを `.streamlit/secrets.toml` にコピー
#   2. 各値を実際のものに置き換える
#   3. `secrets.toml` は .gitignore で除外されているのでコミットされない
#
# Streamlit Cloud:
#   https://share.streamlit.io/ → アプリの Settings → Secrets に同じ内容を貼り付ける

GA4_MEASUREMENT_ID = "G-XXXXXXXXXX"
OPENAI_API_KEY = "sk-..."

# 管理者専用の更新ボタンを有効化するためのトークン
# 32文字のランダム英数字を推奨
# 生成方法:
#   python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters + string.digits) for _ in range(32)))"
admin_token = "32文字のランダム英数字"
